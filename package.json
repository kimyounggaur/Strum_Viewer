{
  "name": "lesson-designer-strum-viewer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "prepare:strums": "node scripts/prepareStrumAssets.mjs",
    "predev": "npm run prepare:strums",
    "dev": "node ./node_modules/vite/bin/vite.js",
    "prebuild": "npm run prepare:strums",
    "build": "node ./node_modules/typescript/bin/tsc -b && node ./node_modules/vite/bin/vite.js build",
    "preview": "node ./node_modules/vite/bin/vite.js preview",
    "typecheck": "node ./node_modules/typescript/bin/tsc -b"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.2",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  }
}
